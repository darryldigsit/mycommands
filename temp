# One-time setup (run these sequentially)
sudo apt update && sudo apt upgrade -y
sudo apt install -y python3 python3-pip python3-venv python3-dev build-essential libssl-dev libffi-dev git
sudo mkdir -p /opt/caldera && sudo chown $USER:$USER /opt/caldera
cd /opt/caldera
sudo git clone https://github.com/mitre/caldera.git --recursive .
sudo git checkout 5.3.0
sudo git submodule update --init --recursive
sudo chown -R $USER:$USER /opt/caldera
python3 -m venv caldera_env
source caldera_env/bin/activate
pip install --upgrade pip setuptools wheel
pip install -r requirements.txt

# Subsequent starts (from /opt/caldera directory)
source caldera_env/bin/activate
python3 server.py
